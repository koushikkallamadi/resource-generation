{
  "name": "Characterization Techniques",
  "children": [
    {
      "name": "X-ray Diffraction (XRD)",
      "children": [
        {
          "name": "Principle",
          "children": [
            {
              "name": "Based on constructive interference of monochromatic X-rays"
            },
            {
              "name": "Follows Bragg's Law: nλ = 2d sinθ"
            }
          ]
        },
        {
          "name": "Applications",
          "children": [
            {
              "name": "Identification of unknown crystalline materials/phases"
            },
            {
              "name": "Determination of unit cell dimensions"
            },
            {
              "name": "Measurement of sample purity"
            },
            {
              "name": "Thin film characterization"
            }
          ]
        },
        {
          "name": "Rietveld Method",
          "children": [
            {
              "name": "Mathematical modeling of the entire powder pattern"
            },
            {
              "name": "Minimizes weighted sum of squared differences"
            }
          ]
        }
      ]
    },
    {
      "name": "Scanning Probe Microscopy (SPM)",
      "children": [
        {
          "name": "Principle",
          "children": [
            {
              "name": "High definition imaging via physical probe scanning"
            },
            {
              "name": "Utilizes feedback system based on tip-sample interactions"
            }
          ]
        },
        {
          "name": "Types",
          "children": [
            {
              "name": "Scanning Tunneling Microscope (STM): Uses electron tunneling current"
            },
            {
              "name": "Atomic Force Microscope (AFM): Monitors attraction/repulsion forces"
            }
          ]
        },
        {
          "name": "AFM Modes",
          "children": [
            {
              "name": "Contact mode"
            },
            {
              "name": "Noncontact mode"
            },
            {
              "name": "Tapping mode"
            }
          ]
        }
      ]
    },
    {
      "name": "Electron Microscopy",
      "children": [
        {
          "name": "Scanning Electron Microscope (SEM)",
          "children": [
            {
              "name": "Uses electron beam to scan surface topography"
            },
            {
              "name": "Detects secondary and backscattered electrons"
            }
          ]
        },
        {
          "name": "Transmission Electron Microscope (TEM)",
          "children": [
            {
              "name": "Uses transmitted electron beam for internal structures"
            },
            {
              "name": "Requires ultra-thin specimens"
            }
          ]
        }
      ]
    },
    {
      "name": "Spectroscopy",
      "children": [
        {
          "name": "UV-VIS-NIR Spectroscopy",
          "children": [
            {
              "name": "Principle: Measures absorbance of electromagnetic radiation"
            },
            {
              "name": "Follows Beer-Lambert Law"
            }
          ]
        }
      ]
    },
    {
      "name": "Thermal Analysis",
      "children": [
        {
          "name": "Thermogravimetric Analysis (TGA)",
          "children": [
            {
              "name": "Monitors mass change vs. temperature"
            }
          ]
        },
        {
          "name": "Differential Thermal Analysis (DTA)",
          "children": [
            {
              "name": "Measures temperature difference between sample and reference"
            }
          ]
        },
        {
          "name": "Differential Scanning Calorimetry (DSC)",
          "children": [
            {
              "name": "Measures heat flow differences vs. temperature"
            }
          ]
        }
      ]
    }
  ]
}